<!-- ===== MODAL / OFFERS (попап из QUIZ) ===== -->
<div class="offers-modal" id="offersModal" aria-hidden="true">
  <div class="offers-backdrop" id="offersBackdrop"></div>

  <div class="offers-dialog" role="dialog" aria-modal="true" aria-labelledby="offersTitle">
    <button class="offers-close" id="offersClose" aria-label="Закрыть">✕</button>

    <h3 class="offers-title" id="offersTitle">Подходящие предложения</h3>
    <p class="offers-subtitle">Выбрали для вас лучшие варианты. Нажмите «Перейти», чтобы оформить заявку.</p>

    <div class="offers-grid" id="offersGrid"><!-- Карточки генерируются JS --></div>

    <div class="offers-footnote">* Условия и ставки определяет МФО. Перед оформлением внимательно ознакомьтесь с договором. 18+.</div>
  </div>
</div>

<style>
:root{
  --brand:#0099ff;
  --text:#111;
  --muted:#6b7280;
  --card:#fff;
}

/* ===== МОДАЛКА ===== */
.offers-modal{ position:fixed; inset:0; z-index:9999; display:none; }
.offers-modal[aria-hidden="false"]{ display:block; }

.offers-backdrop{
  position:absolute; inset:0; background:rgba(0,0,0,.55);
  opacity:0; transition:opacity .2s ease;
}
.offers-modal[aria-hidden="false"] .offers-backdrop{ opacity:1; }

.offers-dialog{
  position:relative; max-width:960px; margin:20px auto;
  background:#fff; border-radius:12px; padding:12px;
  box-shadow:none;
  transform:translateY(10px); opacity:0; transition:transform .2s ease, opacity .2s ease;
}
.offers-modal[aria-hidden="false"] .offers-dialog{ transform:translateY(0); opacity:1; }

/* Мобайл: вертикальная прокрутка окна */
@media (max-width:960px){
  .offers-dialog{
    margin:6vh 8px; padding:10px; border-radius:10px;
    max-height:88vh;
    overflow-y:auto;                 /* скролл внутри модалки */
    -webkit-overflow-scrolling:touch;
  }
}

/* Заголовки */
.offers-title{ margin:0 0 4px; font:700 18px/1.25 Arial,Helvetica,sans-serif; color:#000; }
.offers-subtitle{ margin:0 0 8px; font:400 12px/1.4 Arial,Helvetica,sans-serif; color:var(--muted); }

/* Крестик */
.offers-close{
  position:absolute; right:12px; top:10px; width:32px; height:32px;
  border-radius:999px; border:0; background:#fff; color:#111; cursor:pointer;
  box-shadow:0 6px 16px rgba(0,0,0,.12);
}
.offers-close:hover{ background:#eef2f7 }

/* Сетка карточек */
.offers-grid{ display:grid; grid-template-columns:1fr; gap:8px; }
@media(min-width:641px){ .offers-grid{ grid-template-columns:repeat(2,1fr); } }
@media(min-width:961px){ .offers-grid{ grid-template-columns:repeat(3,1fr); } }

/* Карточка — белый фон + тонкая граница между офферами */
.offer-card{
  background:#fff;
  border:1px solid #e5e7eb;        /* граница у каждой карточки */
  border-radius:10px;
  padding:10px;
  display:grid; grid-template-columns:auto 1fr; column-gap:8px;
  align-items:start;
}

/* Лого — без границ и теней */
.offer-logoBox{
  grid-row:1 / 3;
  width:120px; height:100px;
  display:flex; align-items:center; justify-content:center;
  background:#fff; border:none; box-shadow:none;
}
.offer-logo{ width:100%; height:100%; object-fit:contain; border:0; box-shadow:none; }

/* Текст */
.offer-list{ list-style:none; margin:0; padding:0; }
.offer-list li{
  margin:2px 0; padding-left:14px; position:relative;
  color:#000; font:400 12px/1.4 Arial,Helvetica,sans-serif;
}
.offer-list li::before{ content:"•"; color:var(--brand); position:absolute; left:0; top:0; line-height:1.3; }

/* Кнопка — чёрный текст строго */
.offer-btn{
  grid-column:2; justify-self:center; margin-top:6px;
  display:inline-block; padding:8px 12px; border-radius:10px;
  background:var(--brand); color:#fff !important; border:0;
  text-decoration:none; font:700 13px/1 Arial,Helvetica,sans-serif;
  transition:background .2s, transform .1s;
}
.offer-btn:hover{ background:#007fd6 }
.offer-btn:active{ transform:translateY(1px) }

/* Подпись */
.offers-footnote{ margin-top:8px; text-align:center; font:400 11px/1.4 Arial,Helvetica,sans-serif; color:#000; }

/* Блокировка фона */
body.modal-open{ overflow:hidden; }
</style>

<script>
/* Данные офферов (логотипы 60×60) */
const OFFERS_MODAL = [
  { logo:"https://i.ibb.co/PsChNY7b/1756732984-120x120.png", features:["До 100 000 ₽","Решение за 5–15 минут","0% для новых клиентов*"], url:"URL_AFFILIATE_1" },
  { logo:"https://i.ibb.co/zH47JyKZ/1756732951-120x120.png", features:["До 30 000 ₽ на карту","Без звонков","Одобрение до 90%"], url:"URL_AFFILIATE_2" },
  { logo:"https://i.ibb.co/Dgtg2wbn/1756732877-120x120.png", features:["Выдача в тот же день","Пролонгация срока","Без справок и залога"], url:"URL_AFFILIATE_3" },
  { logo:"https://i.ibb.co/mVPVHJzX/1756733061-120x120.png", features:["До 70 000 ₽","Плохая КИ — ок","Мгновенное перечисление"], url:"URL_AFFILIATE_4" },
  { logo:"https://i.ibb.co/5XjDb6Q4/1756733020-120x120.png", features:["До 50 000 ₽","Подбор по параметрам","Прозрачные условия"], url:"URL_AFFILIATE_5" }
];

function renderOffersIntoModal(){
  const grid = document.getElementById('offersGrid');
  if(!grid) return;
  grid.innerHTML = '';
  OFFERS_MODAL.forEach(o=>{
    const card = document.createElement('article');
    card.className = 'offer-card';
    card.innerHTML = `
      <div class="offer-logoBox">
        <img class="offer-logo" src="${o.logo}" alt="Логотип">
      </div>
      <ul class="offer-list">
        ${o.features.map(f=>`<li>${f}</li>`).join('')}
      </ul>
      <a class="offer-btn" href="${o.url}" target="_blank" rel="nofollow noopener">Перейти</a>
    `;
    grid.appendChild(card);
  });
}

(function(){
  const openBtn = document.getElementById('showOffers');     // кнопка из QUIZ
  const modal   = document.getElementById('offersModal');
  const closeX  = document.getElementById('offersClose');
  const back    = document.getElementById('offersBackdrop');
  if(!modal || !openBtn) return;

  function openModal(){ renderOffersIntoModal(); modal.setAttribute('aria-hidden','false'); document.body.classList.add('modal-open'); }
  function closeModal(){ modal.setAttribute('aria-hidden','true'); document.body.classList.remove('modal-open'); }

  openBtn.addEventListener('click', openModal);
  closeX.addEventListener('click', closeModal);
  back.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e)=>{ if(e.key==='Escape') closeModal(); });
})();
</script>
